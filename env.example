# Cloud AI Planner - Environment Variables Template
# Copy these values to Lambda → Configuration → Environment variables

# ============================================
# REQUIRED - CORS Configuration
# ============================================
# Comma-separated list of allowed origins for CORS
# Include localhost for development and production domains
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://www.simpleaiplanner.com,https://simpleaiplanner.com

# ============================================
# REQUIRED - Cognito Authentication
# ============================================
COGNITO_REGION=us-west-1
COGNITO_USER_POOL_ID=us-west-1_SsXJndL6f
COGNITO_APP_CLIENT_ID=34ec70utdus79c7l9ru3frmf40

# ============================================
# REQUIRED - Database Connection
# ============================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ============================================
# REQUIRED - OpenAI API
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# OPTIONAL - AWS Configuration
# ============================================
# AWS Region (defaults to us-west-1 if not set)
AWS_REGION=us-west-1

# ============================================
# OPTIONAL - AWS Textract Configuration
# ============================================
# Required for async multi-page PDF processing
# If not set, defaults will be used but async processing may fail
TEXTRACT_S3_BUCKET=your-textract-bucket-name
TEXTRACT_SNS_TOPIC_ARN=arn:aws:sns:us-west-1:123456789012:textract-topic
TEXTRACT_SQS_QUEUE_URL=https://sqs.us-west-1.amazonaws.com/123456789012/textract-queue
TEXTRACT_ROLE_ARN=arn:aws:iam::123456789012:role/textract-role

# Optional: separate queue for syllabus pipeline (API returns 202; run syllabus_worker.py or Lambda SQS trigger)
# SYLLABUS_PROCESSING_QUEUE_URL=https://sqs.us-west-1.amazonaws.com/123456789012/syllabus-jobs

